# ============================================================
# 吟彩销售订单系统 - NAS 部署环境变量模板
# 在 NAS 上：cp env.template .env  然后编辑 .env 填写实际值
# ============================================================

# ── 数据库 ──────────────────────────────────────────────────
# DATABASE_URL 由 docker-compose.yml 自动注入，无需手动填写
MYSQL_ROOT_PASSWORD=请修改为强密码_root
MYSQL_PASSWORD=请修改为强密码_app

# ── 认证密钥 ────────────────────────────────────────────────
# 用 openssl rand -hex 32 生成 64 位随机字符串
JWT_SECRET=请用openssl_rand_-hex_32生成

# ── MinIO 文件存储 ───────────────────────────────────────────
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=请修改为强密码_minio
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=yincai-files
# 浏览器访问图片时使用的公网地址（填 NAS 的 IP，如 192.168.2.97）
MINIO_PUBLIC_ENDPOINT=http://192.168.2.97:9000

# ── PDF 生成（Puppeteer）────────────────────────────────────
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

